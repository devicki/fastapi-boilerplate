{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ FastAPI (uvicorn, reload + subprocess)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8088", "--reload"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "subProcess": true,
      "justMyCode": true
      // 필요시 "python": "C:\\Users\\camel\\.pyenv\\pyenv-win\\versions\\3.10.11\\python.exe"
    }
  ]
}
