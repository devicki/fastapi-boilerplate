# FastAPI Boilerplate Environment Variables

# ===============================================
# APPLICATION SETTINGS
#
# 개발 편의를 위한 로그인 자동화 설정 - local
# 개발 / 운영 배포시에는 false 로 설정
# ===============================================
LOG_LEVEL=INFO
LOCAL_ENABLE_AUTO_LOGIN=true

# ===============================================
# CORS SETTINGS
# ===============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===============================================
# DATABASE SETTINGS
#
# ENABLE_SQL_LOGGING: SQL 쿼리문 디버깅용
# 운영 배포시에는 false 로 설정
# ===============================================
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_SERVICE_NAME=app_db
ENABLE_SQL_LOGGING=true

# ===============================================
# REDIS SETTINGS
# ===============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===============================================
# JWT SETTINGS
#
# ACCESS_TOKEN_EXPIRE_MINUTES : 액세스 토큰 만료 시간 (분 단위)
# REFRESH_TOKEN_EXPIRE_DAYS : 리프레시 토큰 만료 시간 (일 단위)
# ===============================================
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ===============================================
# AUTHENTICATION SETTINGS
#
# MAX_LOGIN_FAIL_COUNT: 로그인 실패 최대 횟수
# ===============================================
MAX_LOGIN_FAIL_COUNT=5

# ===============================================
# COOKIE SETTINGS
#
# COOKIE_SECURE: true = HTTPS 전용, false = HTTP 및 HTTPS 모두 허용
# USE_HOST_PREFIX: HTTPS가 아닌 환경에서는 false
# COOKIE_DOMAIN: 빈 값이면 domain 속성 없음
# ===============================================
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_PATH=/
USE_HOST_PREFIX=false
COOKIE_SAMESITE=lax

# ===============================================
# TIMEZONE SETTINGS
# ===============================================
APP_TIMEZONE=UTC
